<?xml version="1.0" encoding="utf-8"?>
<!--
  Accessibility service configuration for OverlayLang.
  Listens to text changes and window changes across all apps so the
  overlay can display real-time translations and word explanations.
-->
<accessibility-service
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="
        typeViewTextChanged|
        typeWindowContentChanged|
        typeViewFocused|
        typeWindowStateChanged"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:accessibilityFlags="
        flagReportViewIds|
        flagRetrieveInteractiveWindows"
    android:canRetrieveWindowContent="true"
    android:notificationTimeout="150"
    android:settingsActivity="com.overlaylang.app.MainActivity" />
