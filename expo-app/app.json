{
  "expo": {
    "name": "OverlayLang",
    "slug": "overlay-lang",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "overlaylang",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#060810",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#060810"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#060810"
      },
      "package": "com.overlaylang.app",
      "versionCode": 1
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-av",
        {
          "microphonePermission": "Allow OverlayLang to access your microphone for voice input."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
